# ── Wijs environment variables ──────────────────────────────────────────────
# Copy this file to .env (local) or paste into Vercel → Settings → Environment Variables

# PostgreSQL connection string (get this from Neon / Supabase / Railway)
DATABASE_URL=postgresql://user:password@host:5432/wijs

# JWT signing secret — generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=replace-with-a-long-random-string

# The origin your React app runs on (used for CORS on the API server)
# Local dev: http://localhost:3000  |  Production: https://wijs-kappa.vercel.app
CLIENT_ORIGIN=http://localhost:3000

# React app — API base URL (prefix REACT_APP_ so CRA bundles it into the frontend)
# Local dev: http://localhost:4000/api  |  Production: your API URL
REACT_APP_API_BASE=http://localhost:4000/api
